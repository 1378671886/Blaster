# 忽略所有文件和文件夹
*

# 保留文件夹
!/Source/
!/Source/**/*
!/Config/
!/Config/**/*
!/Plugins/

# 只保留 Plugins 中的源代码，忽略编译产物
!/Plugins/**/Source/
!/Plugins/**/Source/**/*
!/Plugins/**/*.uplugin
!/Plugins/**/*.h
!/Plugins/**/*.cpp

# 忽略 Plugins 中的编译产物
/Plugins/**/Binaries/
/Plugins/**/Intermediate/

# 保留根目录文件
!*.uproject
!.gitignore
!.gitattributes