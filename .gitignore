# 忽略所有文件和文件夹
*

# 保留 Source 和 Config（主项目）
!/Source/
!/Source/**/*
!/Config/
!/Config/**/*

# 保留 Plugins 文件夹本身
!/Plugins/
!/Plugins/**/

# 保留每个插件的 .uplugin 文件
!/Plugins/**/*.uplugin

# 保留每个插件的 Source 文件夹及其所有内容
!/Plugins/**/Source/
!/Plugins/**/Source/**/*

# 保留每个插件的 Config 文件夹及其所有内容
!/Plugins/**/Config/
!/Plugins/**/Config/**/*

# 忽略 Plugins 中的编译产物和临时文件
/Plugins/**/Binaries/
/Plugins/**/Intermediate/
/Plugins/**/DerivedDataCache/
/Plugins/**/Binaries/**
/Plugins/**/Intermediate/**
/Plugins/**/DerivedDataCache/**

# 保留根目录文件
!*.uproject
!.gitignore
!.gitattributes

# 全局忽略 UE 生成的编译产物
/Binaries/
/Intermediate/
/Saved/
/DerivedDataCache/
/.vs/